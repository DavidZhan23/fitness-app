# 复制为 deploy/.env 后修改（在服务器 deploy 目录执行: cp .env.example .env）
POSTGRES_PASSWORD=请改成强密码至少16位
JWT_SECRET=请改成至少32位随机字符串

# 注册邀请密钥（注册页需填写相同字符串，默认 454676）
REGISTRATION_KEY=454676

# 浏览器访问前端的地址（用 IP 部署时填 http://公网IP，不要末尾斜杠）
CORS_ORIGIN=http://你的公网IP

# 多个来源用逗号分隔，例如:
# CORS_ORIGIN=http://123.45.67.89,https://你的域名.com

# DeepSeek：记运动/记饮食 AI 估算千卡（仅服务端，勿泄露到前端）
DEEPSEEK_API_KEY=

# 通义千问视觉：记饮食「拍照识别」（仅服务端）
DASHSCOPE_API_KEY=
# KCAL_VISION_MODEL=qwen3-vl-flash

# 开发者账号（逗号分隔）：可访问周报 API，并在 App「设置」页看到「开发者后台」
# 示例：DEVELOPER_EMAILS=owner@example.com
DEVELOPER_EMAILS=owner@example.com

# 兼容旧配置：未设置 DEVELOPER_EMAILS 时，仍使用 ADMIN_EMAILS 作为开发者白名单
# ADMIN_EMAILS=owner@example.com

# 关闭自动周报 cron（设为 1 可临时禁用，不影响手动 regenerate）
# WEEKLY_REPORT_DISABLED=
