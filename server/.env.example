PORT=3001
CORS_ORIGIN=http://localhost:5173

# DeepSeek AI 估算千卡（仅服务端，勿写入前端）
DEEPSEEK_API_KEY=
# 可选：默认 deepseek-chat（快）；勿用 deepseek-reasoner
# DEEPSEEK_MODEL=deepseek-chat
