# 复制为 server/.env 后修改（本地开发）
# 先启动数据库: brew services start postgresql@16
# 详见 docs/ops/本地数据库启停.md

DATABASE_URL=postgres://localhost:5432/fitness
# 必填：缺失时 API 拒绝启动（勿使用弱默认值）
JWT_SECRET=change_me_jwt_secret_min_32_chars_local_dev
REGISTRATION_KEY=454676
PORT=3001
CORS_ORIGIN=http://localhost:5173

# 开发者邮箱（逗号分隔）：周报 API + App「开发者后台」入口
# DEVELOPER_EMAILS=you@example.com

# DeepSeek AI 估算千卡（仅服务端，勿写入前端）
DEEPSEEK_API_KEY=
# 可选：默认 deepseek-chat（快）；勿用 deepseek-reasoner
# DEEPSEEK_MODEL=deepseek-chat

# 通义千问视觉：记饮食「拍照识别」千卡（仅服务端）
DASHSCOPE_API_KEY=
# 可选：默认 qwen3-vl-flash
# KCAL_VISION_MODEL=qwen3-vl-flash
# DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
