{
  "name": "fitness-tracker-pwa",
  "private": true,
  "version": "1.5.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "verify": "bash scripts/verify-local.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "cleanup:e2e-users": "node scripts/cleanup-e2e-users.mjs",
    "preview": "vite preview",
    "prepare": "husky",
    "ai-flow": "bash scripts/ai-flow.sh",
    "new-feature": "bash scripts/new-feature.sh",
    "req:list": "bash scripts/req-list.sh",
    "diagrams:regen": "bash scripts/regen-diagrams.sh",
    "deploy:tencent": "bash scripts/deploy-tencent.sh",
    "deploy:tencent:api": "bash scripts/deploy-tencent.sh --api",
    "changelog:dedupe": "node scripts/dedupe-changelog.mjs",
    "check:milestones": "node scripts/check-milestone-status.mjs",
    "check:theme-contrast": "node scripts/check-theme-contrast.mjs",
    "check:mobile-layout": "playwright test e2e/mobile-layout.spec.ts",
    "check:today-responsive": "playwright test e2e/today-responsive.spec.ts",
    "check:site-responsive": "playwright test e2e/site-responsive.spec.ts"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4"
  }
}
